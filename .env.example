# PCForge AI — Environment Variables
# Copy this file to .env and fill in your values

# ── App Settings ──────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database (PostgreSQL) ─────────────────────────────────────
# Currently unused (stateless mode). Uncomment when enabling persistence.
# DATABASE_URL=postgresql://pcforge:password@localhost:5432/pcforge_db

# ── Redis Cache ───────────────────────────────────────────────
# Currently unused. Uncomment when enabling pricing cache.
# REDIS_URL=redis://localhost:6379/0
# PRICE_CACHE_TTL_SECONDS=3600

# ── Pricing API Keys (Plug-in Ready) ─────────────────────────
# Leave empty to use simulated pricing layer.
# PCPARTPICKER_API_KEY=
# NEWEGG_API_KEY=

# ── ML Model ──────────────────────────────────────────────────
MODEL_PATH=data/models/price_model.pkl
ENCODER_PATH=data/models/feature_encoder.pkl

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
